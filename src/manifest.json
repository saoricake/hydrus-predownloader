{
  "manifest_version": 3,
  "name": "Hydrus Downloader",
  "version": "1.0",
  "description": "Downloads images from certain websites.",

  "permissions": [],
  "host_permissions": ["*://www.pixiv.net/*"],
  "browser_specific_settings": {
    "gecko": { "id": "HydrusDownloader@nothinghappens.neocities.org" }
  },

  "content_scripts": [
    {
      "matches": ["*://www.pixiv.net/*"],
      "css": ["css/layout.css", "css/style.css"],
      "js": ["js/consts.js", "js/utils.js"]
    },
    {
      "matches": ["*://www.pixiv.net/*"],
      "js": ["js/data/pixiv.js"]
    },
    {
      "matches": ["*://www.pixiv.net/*"],
      "js": [
        "js/download.js",
        "js/html.js",
        "js/init.js",
        "js/run.js"
      ]
    }
  ]
}
